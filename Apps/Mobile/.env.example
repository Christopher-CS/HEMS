# Copy to `.env` and adjust (never commit real URLs/secrets).
# Expo exposes only variables prefixed with EXPO_PUBLIC_ to your JS bundle.
# Restart Metro after changing these values.

# Backend HTTP base URL (no trailing slash). Examples:
#   Same machine, web/iOS sim:     http://localhost:4000
#   Android emulator → host PC:     http://10.0.2.2:4000
#   Physical phone → your PC LAN:   http://192.168.1.50:4000
EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:4000

# How commands are sent: http | socket | mock
# Overrides app.json extra.transportMode when set.
EXPO_PUBLIC_TRANSPORT_MODE=http

# Where library lists load from: http | mock
EXPO_PUBLIC_LIBRARY_SOURCE=http

# Where device list loads from: http | mock
EXPO_PUBLIC_DEVICES_SOURCE=http
